# App
APP_ENV=development
APP_PORT=8080
APP_SECRET=change_this_to_a_secure_random_string_min_32_chars
REFRESH_TOKEN_SECRET=change_this_to_a_different_secure_random_string_min_32_chars

ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DATABASE_URL=postgresql://azzet:azzet123@localhost:5432/azzet?sslmode=disable

# Redis (Cache & Asynq Backend)
REDIS_URL=redis://localhost:6379

# NATS JetStream (Event Streaming)
NATS_URL=nats://localhost:4222

# Cloudflare R2 (Object Storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=azzet-documents
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# AI / OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4-turbo

# Zenziva WhatsApp OTP
ZENZIVA_URL=https://console.zenziva.net/waofficial/api/sendWAOfficial/
ZENZIVA_USERKEY=your_zenviva_user_key
ZENZIVA_PASSKEY=your_zenviva_pass_key
ZENZIVA_BRAND=Azzet

# Payment Gateway (Xendit)
XENDIT_API_KEY=your_xendit_api_key
XENDIT_WEBHOOK_SECRET=your_xendit_webhook_secret
XENDIT_CALLBACK_URL=http://localhost:8080/api/v1/webhooks/xendit
XENDIT_SUCCESS_URL=http://localhost:3000/payment/success
XENDIT_FAILURE_URL=http://localhost:3000/payment/failed

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@azzet.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@azzet.com

# Worker
WORKER_CONCURRENCY=50
