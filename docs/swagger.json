        "/auth/otp/request": {
            "post": {
                "description": "Send a 6-digit OTP to the user's WhatsApp number via Zenziva. Valid for 5 minutes, max 3 attempts.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Request OTP code via WhatsApp",
